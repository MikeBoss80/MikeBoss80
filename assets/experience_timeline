    <rect x="0" y="0" width="300" height="190" rx="14" fill="#1a1a2e" stroke="#2a2a4e" stroke-width="1"/>
    <rect x="0" y="0" width="300" height="190" rx="14" fill="url(#card3Grad)"/>
    
    <rect x="0" y="0" width="6" height="190" rx="3" fill="#A78BFA"/>
    
    <circle cx="30" cy="30" r="18" fill="#A78BFA" opacity="0.15"/>
    <text x="30" y="35" fill="#A78BFA" font-size="16" text-anchor="middle">💎</text>
    
    <text x="60" y="25" fill="#A78BFA" font-size="10" font-weight="700" letter-spacing="1">ABR 2024 - JUL 2025</text>
    <text x="60" y="48" fill="white" font-size="16" font-weight="700">Full Stack Developer</text>
    <text x="60" y="70" fill="#8888aa" font-size="11">BarberB — Tecnoparque · Freelance</text>
    
    <text x="20" y="98" fill="#ccccdd" font-size="10.5">
