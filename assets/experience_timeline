    <line x1="550" y1="410" x2="580" y2="410" stroke="#4ECDC4" stroke-width="1" stroke-dasharray="4,4"/>
    <line x1="750" y1="280" x2="780" y2="280" stroke="#A78BFA" stroke-width="1" stroke-dasharray="4,4"/>
